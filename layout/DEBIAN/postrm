#!/bin/sh
set -e

echo "[Skyglow] Running removal script"

# Detect rootless
JB_PREFIX=""
if [ -d /var/jb ]; then
    JB_PREFIX="/var/jb"
fi

PLIST_PATH="$JB_PREFIX/Library/LaunchDaemons/com.skyglow.snd.plist"
KEYS_PATH="$JB_PREFIX/Library/PreferenceBundles/SkyglowNotificationsDaemonSettings.bundle/Keys"

echo "[Skyglow] Using prefix: ${JB_PREFIX:-/}"

# Unload daemon (modern jailbreaks)
if [ -f "$PLIST_PATH" ]; then
    if command -v launchctl >/dev/null 2>&1; then
        echo "[Skyglow] Unloading daemon with launchctl"
        launchctl unload "$PLIST_PATH" 2>/dev/null || true
    else
        echo "[Skyglow] Unloading daemon with launchctl"
        launchctl unload "$PLIST_PATH" 2>/dev/null || true
    fi
else
    echo "[Skyglow] Plist not found: $PLIST_PATH"
fi

# Optional: remove plist file
# rm -f "$PLIST_PATH"

# Optional: remove keys (if you want to wipe state on uninstall)
# rm -rf "$KEYS_PATH"

echo "[Skyglow] Removal complete"
exit 0